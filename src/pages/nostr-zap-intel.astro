---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Hr from "@/components/Hr.astro";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>kheAI: Nostr Lightning Zap Intelligence</title>

    <!-- Tailwind CDN for quick prototyping (replace with project Tailwind in production) -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

    <style>
      body { font-family: 'Inter', sans-serif; background-color: #f8fafc; color: #0f172a; }
      .chart-container { position: relative; width: 100%; max-width: 100%; margin-left: auto; margin-right: auto; height: 350px; max-height: 400px; }
      @media (min-width: 768px) { .chart-container { height: 400px; } }
      .gradient-text { background: linear-gradient(to right, #3b82f6, #06b6d4); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
      .card { background-color: #ffffff; border-radius: 1rem; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05); padding: 1.5rem; transition: transform 0.2s; border-top: 4px solid #3b82f6; }
      .card:hover { transform: translateY(-2px); }
      .badge { background-color: #eab308; color: #0f172a; padding: 0.25rem 0.75rem; border-radius: 9999px; font-weight: 600; font-size: 0.875rem; }
      .flow-box { background-color: #f1f5f9; border: 2px solid #cbd5e1; border-radius: 0.5rem; padding: 1rem; text-align: center; font-weight: 600; }
      .arrow-down { text-align: center; font-size: 1.5rem; color: #3b82f6; margin: 0.5rem 0; }
    </style>
  </head>

  <body class="antialiased">

    <div id="meta-confirmations" style="display:none;">
      Explicitly confirmed: NEITHER Mermaid JS NOR SVG were used anywhere in this output.
      Chosen Palette: Brilliant Blues & Energetic Yellows (Navy #0f172a, Blue #3b82f6, Cyan #06b6d4, Yellow #eab308, White #ffffff).
      Narrative Plan: 1. Introduction to the Market Failure (Noise). 2. The kheAI/Nostr Solution (Cryptographic Intent). 3. Data Overview (2026 Metrics). 4. Product Breakdown (The 4 Engines). 5. Competitive Moat & Monetization.
      Visualization Plan:
      1. Radar Chart -> Compare -> kheAI vs Competitors (Showcase superiority across key metrics).
      2. Area Chart -> Change -> Nostr Zap Volume (Show network growth and viability).
      3. Bar Chart -> Compare -> Cost of Forging Engagement (Highlighting the "Proof-of-Work" deficit in Web2).
      4. Doughnut Chart -> Inform/Composition -> Lead Confidence Score Breakdown (Explain the AI weighting).
    </div>

    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex-shrink-0 flex items-center font-bold text-2xl tracking-tight text-gray-900">
            <span class="text-yellow-500 mr-2">⚡</span> khe<span class="text-blue-500">AI</span>
          </div>
          <div class="hidden md:flex space-x-8">
            <a href="#crisis" class="text-gray-600 hover:text-blue-600 font-medium">The Crisis</a>
            <a href="#solution" class="text-gray-600 hover:text-blue-600 font-medium">The Solution</a>
            <a href="#products" class="text-gray-600 hover:text-blue-600 font-medium">Products</a>
            <a href="#moat" class="text-gray-600 hover:text-blue-600 font-medium">Competitive Moat</a>
          </div>
        </div>
      </div>
    </nav>

    <header class="bg-[#0f172a] text-white py-20 px-4">
      <div class="max-w-5xl mx-auto text-center">
        <span class="badge mb-4 inline-block">2026 Market Intelligence Brief</span>
        <h1 class="text-4xl md:text-6xl font-bold mb-6">Nostr Lightning <span class="gradient-text">Zap Intelligence</span></h1>
        <p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto">Converging decentralized social graphs with cryptographically verifiable Lightning micropayments to deliver high-confidence commercial intent signals.</p>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <!-- content unchanged structurally: crisis, solution, products, moat, etc. -->

      <section id="crisis" class="mb-20">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">The Market Failure: <span class="text-blue-600">Collapse of Traditional Signal</span></h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">The B2B lead generation industry faces a critical signal-to-noise crisis. Legacy tools aggregate easily forged metrics to guess at sentiment, while on-chain tools track money but miss the social context.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div class="space-y-6">
            <div class="card border-t-[#ec4899]">
              <h3 class="text-xl font-bold mb-2 flex items-center"><span class="text-2xl mr-2">🤖</span> The "Proof-of-Work" Deficit</h3>
              <p class="text-gray-600">A "like" or "repost" is a zero-cost action. In the era of LLM bot nets, standard engagement metrics have zero correlation with genuine commercial intent.</p>
            </div>
            <div class="card border-t-[#ec4899]">
              <h3 class="text-xl font-bold mb-2 flex items-center"><span class="text-2xl mr-2">🔒</span> Centralized Blindness</h3>
              <p class="text-gray-600">Legacy platforms are walling off APIs, making data ingestion prohibitively expensive and subject to arbitrary corporate censorship.</p>
            </div>
          </div>
          <div class="card">
            <h3 class="text-lg font-bold text-center mb-4">Cost to Forge Engagement (Estimated USD)</h3>
            <div class="chart-container">
              <canvas id="costChart"></canvas>
            </div>
            <p class="text-sm text-gray-500 mt-4 text-center">Traditional metrics cost fractions of a cent to automate. A NIP-57 Zap requires actual capital layout, filtering out noise natively.</p>
          </div>
        </div>
      </section>

      <section id="solution" class="mb-20 bg-blue-50 p-8 rounded-2xl border border-blue-100">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">The kheAI Solution: <span class="text-blue-600">Economic Proof</span></h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">By tapping into the permissionless Nostr protocol, kheAI tracks actual, settled financial transactions (Lightning Zaps) natively embedded in public social interactions.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-12 text-center">
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
            <div class="text-4xl font-bold text-blue-600 mb-2">~6.6M</div>
            <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Weekly Zap Sats</div>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
            <div class="text-4xl font-bold text-cyan-500 mb-2">2,700+</div>
            <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Weekly Active Zappers</div>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
            <div class="text-4xl font-bold text-yellow-500 mb-2">13M+</div>
            <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Historical Zaps</div>
          </div>
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
            <div class="text-4xl font-bold text-pink-500 mb-2">43k+</div>
            <div class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Weekly Active Pubkeys</div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-1 gap-8">
          <div class="card">
            <h3 class="text-lg font-bold text-center mb-4">Network Health: Weekly Bitcoin Embedded in Social Protocol</h3>
            <div class="chart-container">
              <canvas id="volumeChart"></canvas>
            </div>
            <p class="text-sm text-gray-500 mt-4 text-center">kheAI leverages this growing, unforgeable data stream to map the economic attention graph of the Web3 and infrastructure space.</p>
          </div>
        </div>
      </section>

      <section id="products" class="mb-20">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Core Products: <span class="text-cyan-500">From Raw Data to Intelligence</span></h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">kheAI abandons traditional dashboards for four high-value intelligence streams processed by our proprietary AI engine.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="card">
            <h3 class="text-xl font-bold mb-3 text-blue-600">🗺️ Economic Attention Graph</h3>
            <p class="text-gray-600 mb-4">A multi-dimensional, payment-weighted knowledge graph. Answers high-value VC questions by mapping who funds which developers and which niches attract capital.</p>
            <div class="bg-gray-50 p-4 rounded text-sm font-mono text-gray-700 overflow-x-auto">
              Pubkey_A → *zaps* → Dev_B → *mentions* "Self-Custody" → *follows* Pubkey_C
            </div>
          </div>

          <div class="card">
            <h3 class="text-xl font-bold mb-3 text-cyan-500">📡 Market Radar</h3>
            <p class="text-gray-600 mb-4">Tracks "Zap Timing" (time-concentration of payments) to detect emerging narratives before they trend. A cluster of high-value zaps signals viral tool releases or completed bounties.</p>
          </div>

          <div class="card">
            <h3 class="text-xl font-bold mb-3 text-yellow-500">🎯 Actionable Lead Alerts</h3>
            <p class="text-gray-600 mb-4">Delivers highly vetted lead profiles directly to CRMs via NIP-17 secure direct messages. Avoids generic keywords in favor of cryptographically proven intent.</p>
            <div class="mt-4">
              <h4 class="font-semibold text-sm text-gray-700 mb-2">kheAI Confidence Score Composition</h4>
              <div class="chart-container" style="height: 200px;">
                <canvas id="scoreChart"></canvas>
              </div>
            </div>
          </div>

          <div class="card">
            <h3 class="text-xl font-bold mb-3 text-pink-500">🏆 Developer Reputation Score</h3>
            <p class="text-gray-600 mb-4">Replacing noisy metrics like GitHub stars with "Proof-of-Value." Calculated by sats received, payer uniqueness, retention, and technical context.</p>
            <div class="flex flex-col space-y-2 mt-6">
              <div class="flow-box">NIP-57 Zap Receipt (Kind 9735)</div>
              <div class="arrow-down">↓</div>
              <div class="flow-box border-blue-400 bg-blue-50 text-blue-800">kheAI Vector DB & AI Swarm</div>
              <div class="arrow-down">↓</div>
              <div class="flow-box border-green-400 bg-green-50 text-green-800">Verified Proof-of-Value Score</div>
            </div>
          </div>
        </div>
      </section>

      <section id="moat" class="mb-20">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Competitive Moat: <span class="text-blue-600">The kheAI Advantage</span></h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">APIs are easily cloned. kheAI's defensibility lies in its historical database, identity graph, and proprietary intent taxonomy.</p>
        </div>

        <div class="card md:col-span-2 mb-8">
          <h3 class="text-lg font-bold text-center mb-4">Feature Dominance Matrix</h3>
          <div class="chart-container" style="max-width: 600px;">
            <canvas id="radarChart"></canvas>
          </div>
        </div>

        <div class="overflow-x-auto rounded-lg shadow border border-gray-200">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Platform Type</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Examples</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Core Metric</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Weakness vs kheAI</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Legacy Social</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Hootsuite, Sprout</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Likes, Keywords</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-red-500 font-medium">No financial signal; bot heavy</td>
              </tr>
              <tr class="bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">On-Chain Intel</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Nansen, Arkham</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Token Transfers</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-red-500 font-medium">Lacks social context</td>
              </tr>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Nostr Clients</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Primal, Damus</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Speed, UI</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-red-500 font-medium">B2C focused; no enterprise intel</td>
              </tr>
              <tr class="bg-blue-50 border-l-4 border-blue-500">
                <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-blue-800">kheAI</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-800">Intelligence API</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-800 font-semibold">Verified Zaps + Intent</td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-bold">Unforgeable B2B intent signals</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="bg-[#0f172a] rounded-2xl p-8 md:p-12 text-center text-white shadow-2xl">
        <h2 class="text-3xl font-bold mb-4">Go-To-Market & Monetization</h2>
        <p class="text-gray-300 mb-8 max-w-2xl mx-auto">A Crypto-SaaS model leveraging the community for top-of-funnel growth while securing premium revenue from enterprise intelligence.</p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white/10 p-6 rounded-xl backdrop-blur-sm border border-white/20">
            <div class="text-yellow-400 text-xl font-bold mb-2">Tier 1: Free Radar</div>
            <p class="text-sm text-gray-300 mb-4">Public daily aggregate trends to establish authority and drive viral growth.</p>
            <div class="font-bold text-white">Free</div>
          </div>
          <div class="bg-white/10 p-6 rounded-xl backdrop-blur-sm border border-blue-400/50 transform scale-105 shadow-lg">
            <div class="text-cyan-400 text-xl font-bold mb-2">Tier 2: Agent-as-a-Service</div>
            <p class="text-sm text-gray-300 mb-4">NIP-04/17 DMs. Query the AI swarm for specific pubkey profiles. Paid via Lightning.</p>
            <div class="font-bold text-white">$5 - $20 / Query</div>
          </div>
          <div class="bg-white/10 p-6 rounded-xl backdrop-blur-sm border border-white/20">
            <div class="text-pink-400 text-xl font-bold mb-2">Tier 3: Enterprise SaaS</div>
            <p class="text-sm text-gray-300 mb-4">Full API access, custom intent alerts, and automated CRM webhook integrations.</p>
            <div class="font-bold text-white">$499 - $2,500+ / mo</div>
          </div>
        </div>
      </section>

    </main>

    <script>
      // small helpers moved verbatim from original
      function wrapLabel(label) {
        if (label.length <= 16) return label;
        const words = label.split(' ');
        const lines = [];
        let currentLine = '';
        for (let word of words) {
          if ((currentLine + word).length > 16) {
            if (currentLine) lines.push(currentLine.trim());
            currentLine = word + ' ';
          } else {
            currentLine += word + ' ';
          }
        }
        if (currentLine) lines.push(currentLine.trim());
        return lines;
      }

      const tooltipConfig = {
        callbacks: {
          title: function(tooltipItems) {
            const item = tooltipItems[0];
            let label = item.chart.data.labels[item.dataIndex];
            if (Array.isArray(label)) {
              return label.join(' ');
            } else {
              return label;
            }
          }
        }
      };

      // Charts initialization — runs in the browser when the page loads
      document.addEventListener('DOMContentLoaded', function () {
        const costCtx = document.getElementById('costChart').getContext('2d');
        const rawCostLabels = ['Web2 Like / Heart', 'Web2 Repost / Share', 'Nostr Zap (Avg Entry)', 'Corporate Intent Lead'];
        const processedCostLabels = rawCostLabels.map(wrapLabel);

        new Chart(costCtx, {
          type: 'bar',
          data: {
            labels: processedCostLabels,
            datasets: [{
              label: 'Estimated Cost to Generate (USD)',
              data: [0.001, 0.005, 1.50, 50.00],
              backgroundColor: ['#94a3b8','#64748b','#eab308','#3b82f6'],
              borderRadius: 6
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: tooltipConfig },
            scales: { y: { type: 'logarithmic', title: { display: true, text: 'Cost in USD (Log Scale)' } } }
          }
        });

        const volumeCtx = document.getElementById('volumeChart').getContext('2d');
        const rawVolLabels = ['Jan 26', 'Feb 26', 'Mar 26', 'Apr 26', 'May 26', 'Jun 26'];
        const processedVolLabels = rawVolLabels.map(wrapLabel);

        new Chart(volumeCtx, {
          type: 'line',
          data: {
            labels: processedVolLabels,
            datasets: [{
              label: 'Weekly Zap Volume (Millions of Sats)',
              data: [4.1,4.8,5.2,5.9,6.3,6.6],
              borderColor: '#06b6d4',
              backgroundColor: 'rgba(6, 182, 212, 0.2)',
              fill: true,
              tension: 0.4,
              pointBackgroundColor: '#3b82f6',
              pointRadius: 5
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { tooltip: tooltipConfig },
            scales: { y: { beginAtZero: true, title: { display: true, text: 'Millions of Satoshis' } } }
          }
        });

        const scoreCtx = document.getElementById('scoreChart').getContext('2d');
        const rawScoreLabels = ['Zap Financial Volume','Recipient Graph History','NLP Note Context','Time Clustering'];
        const processedScoreLabels = rawScoreLabels.map(wrapLabel);

        new Chart(scoreCtx, {
          type: 'doughnut',
          data: { labels: processedScoreLabels, datasets: [{ data: [40,30,20,10], backgroundColor: ['#3b82f6','#06b6d4','#eab308','#ec4899'], borderWidth: 0 }] },
          options: { responsive: true, maintainAspectRatio: false, cutout: '60%', plugins: { legend: { position: 'right' }, tooltip: tooltipConfig } }
        });

        const radarCtx = document.getElementById('radarChart').getContext('2d');
        const rawRadarLabels = ['Social Context Data','Financial Proof / Stake','Bot Resistance','B2B Intent Accuracy','API Independence'];
        const processedRadarLabels = rawRadarLabels.map(wrapLabel);

        new Chart(radarCtx, {
          type: 'radar',
          data: {
            labels: processedRadarLabels,
            datasets: [
              { label: 'kheAI (Nostr)', data: [100,100,95,90,100], backgroundColor: 'rgba(59,130,246,0.3)', borderColor: '#3b82f6', pointBackgroundColor: '#0f172a', borderWidth: 2 },
              { label: 'On-Chain Analytics', data: [20,100,90,40,80], backgroundColor: 'rgba(6,182,212,0.2)', borderColor: '#06b6d4', borderWidth: 2 },
              { label: 'Legacy Social Tools', data: [90,0,20,30,10], backgroundColor: 'rgba(236,72,153,0.2)', borderColor: '#ec4899', borderWidth: 2 }
            ]
          },
          options: { responsive: true, maintainAspectRatio: false, plugins: { tooltip: tooltipConfig }, scales: { r: { angleLines: { color: '#e2e8f0' }, grid: { color: '#e2e8f0' }, pointLabels: { font: { size: 11 } }, ticks: { display: false, max: 100, min: 0 } } } }
        });

      });
    </script>
  </body>
</html>
